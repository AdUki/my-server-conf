# Template for immich/.env. Copy to .env and fill in DB_PASSWORD before first compose up.
# setup.sh will copy this file automatically and substitute STORAGE_ROOT for the location paths.

BACKUP_PATH=/media/backup/immich/

# The location where your uploaded files are stored.
UPLOAD_LOCATION=/media/data/immich/library

# The location where your database files are stored. Network shares are not supported for the database.
DB_DATA_LOCATION=/media/data/immich/postgres

# Immich version. Pin to a specific tag (e.g. v2.1.0) or use a major-version stream (v2).
IMMICH_VERSION=v2

# Connection secret for postgres. Use only [A-Za-z0-9] (no special characters or spaces).
# Generate a fresh one with:  openssl rand -hex 24
DB_PASSWORD=CHANGE_ME_BEFORE_FIRST_RUN

# Defaults below this line do not normally need to be changed.
##############################################################################
DB_USERNAME=postgres
DB_DATABASE_NAME=immich
